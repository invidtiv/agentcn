  "framework": "mastra",
  "files": [
    { "path": "config.ts", "type": "registry:file" },
    { "path": "instructions.md", "type": "registry:file" },
    { "path": "memory.ts", "type": "registry:file" },
    { "path": "lib/vector-store.ts", "type": "registry:file" },
    { "path": "tools/list_documents.ts", "type": "registry:file" },
    { "path": "tools/query_pdf.ts", "type": "registry:file" },
    { "path": "workflows/index_pdf.ts", "type": "registry:file" }
  ],
  "dependencies": ["@mastra/core", "@mastra/libsql", "@mastra/memory", "@mastra/rag", "pdf-parse"]
}
