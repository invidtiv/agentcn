{
  "name": "docs-chatbot",
  "type": "registry:block",
  "title": "Docs Chatbot Agent",
  "description": "LangGraph agent that answers questions about a library's functions by looking up structured documentation.",
  "framework": "langgraph",
  "files": [
    {
      "path": "data/functions.json",
      "type": "registry:file"
    },
    {
      "path": "index.ts",
      "type": "registry:file"
    },
    {
      "path": "instructions.md",
      "type": "registry:file"
    },
    {
      "path": "tools/lookup_docs.ts",
      "type": "registry:file"
    }
  ],
  "dependencies": ["@dawn-ai/sdk"]
}
